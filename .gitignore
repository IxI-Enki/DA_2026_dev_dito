# Dev Dito - Git Ignore
# =====================

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/

# =============================================================================
# IDE / Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# =============================================================================
# Environment & Secrets (Constitution Article II-B, VI)
# =============================================================================
.env
.env.local
.env.*.local
*.env

# Zentrale Konfiguration - NIE committen!
config/env.yaml
config/settings.json
!config/PLACEHOLDER_env.yaml

# Secrets-Verzeichnis (Inhalte, nicht Struktur)
config/secrets/*
!config/secrets/.gitkeep
!config/secrets/README.md

# Legacy Secrets in Pipeline-Modulen
pipeline/*/config/env.yaml
pipeline/*/config/settings.json
pipeline/*/config/*.token
pipeline/*/config/*.cert
!pipeline/*/config/PLACEHOLDER_*

# Secret-Dateien (allgemein)
*.pem
*.key
*.cert
*.token
secrets/

# =============================================================================
# Data & Output (large files)
# =============================================================================
data/fetched/
data/evaluated/
data/embeddings/*.jsonl
data/logs/*.log
!data/**/.gitkeep

# Fetched wiki content (large)
content_output/
fetched_at_*/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
!logs/.gitkeep
pipeline/*/logs/
!pipeline/*/logs/.gitkeep

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Temporary files
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
*.cache

# =============================================================================
# Test & Coverage
# =============================================================================
.coverage
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

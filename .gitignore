# Dev Dito - Git Ignore
# =====================

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python dist/ and lib/ EXCEPT in dokuwiki_plugin/
/dist/
/lib/
!/dokuwiki_plugin/dist/
!/dokuwiki_plugin/lib/

# Virtual environments
venv/
ENV/
env/
.venv/

# =============================================================================
# IDE / Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Cursor IDE
.cursor/

# =============================================================================
# Environment & Secrets (Constitution Article II-B, VI)
# =============================================================================
.env
.env.local
.env.*.local
*.env

# Zentrale Konfiguration - NIE committen!
config/env.yaml
config/settings.json

# Config-Vorlagen und Beispiele (WERDEN committet)
!config/PLACEHOLDER_env.yaml
!config/env.minimal.yaml
!config/env.development.yaml

# Secrets-Verzeichnis (Inhalte, nicht Struktur)
config/secrets/*
!config/secrets/.gitkeep
!config/secrets/README.md

# Legacy Secrets in Pipeline-Modulen
pipeline/*/config/env.yaml
pipeline/*/config/settings.json
pipeline/*/config/*.token
pipeline/*/config/*.cert
!pipeline/*/config/PLACEHOLDER_*

# Secret-Dateien (allgemein)
*.pem
*.key
*.cert
*.token
secrets/

# =============================================================================
# Data & Output (large files)
# =============================================================================
# Pipeline output directories (contents ignored, structure kept)
data/fetched/*
!data/fetched/.gitkeep
data/evaluated/*
!data/evaluated/.gitkeep
data/preprocessed/*
!data/preprocessed/.gitkeep
data/embeddings/*
!data/embeddings/.gitkeep

# Pipeline logs (keep status tracking, ignore large logs)
data/logs/*.log
data/logs/pipeline_progress.json
!data/logs/.gitkeep
!data/logs/pipeline_runs.json
!data/logs/pipeline_runs.schema.json

# Fetched wiki content (large)
content_output/
fetched_at_*/

# =============================================================================
# Logs
# =============================================================================
*.log
/logs/
!logs/.gitkeep
pipeline/*/logs/
!pipeline/*/logs/.gitkeep

# Keep data/logs/ directory and tracking files
!data/logs/
data/logs/*.log

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml

# Docker .env (contains local paths, never commit)
backend_services/.env
!backend_services/.env.template

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Temporary files
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
*.cache
nul

# =============================================================================
# Cursor / AI Tool Artifacts
# =============================================================================
*.skill

# =============================================================================
# Test & Coverage
# =============================================================================
.coverage
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Dev Dito - Git Ignore
# =====================

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python dist/ and lib/ EXCEPT in dokuwiki_plugin/
/dist/
/lib/
!/dokuwiki_plugin/dist/
!/dokuwiki_plugin/lib/

# Virtual environments
venv/
ENV/
env/
.venv/

# Linters / type checkers
.ruff_cache/
.mypy_cache/

# =============================================================================
# IDE / Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# .cursor/ is intentionally tracked (Spec-Kit command artifacts)

# =============================================================================
# Environment & Secrets (Constitution Article II-B, VI)
# =============================================================================
.env
.env.local
.env.*.local
*.env

# Zentrale Konfiguration - NIE committen!
config/env.yaml
config/settings.json

# Config-Vorlagen und Beispiele (WERDEN committet)
!config/PLACEHOLDER_env.yaml
!config/env.minimal.yaml
!config/env.development.yaml

# Secrets-Verzeichnis (Inhalte, nicht Struktur)
config/secrets/*
!config/secrets/.gitkeep
!config/secrets/README.md

# Legacy Secrets in Pipeline-Modulen
pipeline/*/config/env.yaml
pipeline/*/config/settings.json
pipeline/*/config/*.token
pipeline/*/config/*.cert
!pipeline/*/config/PLACEHOLDER_*

# Secret-Dateien (allgemein)
*.pem
*.key
*.cert
*.token
/secrets/

# Pipeline env files (local overrides)
pipeline/**/env.yaml

# =============================================================================
# Data & Output (large files)
# =============================================================================
# Pipeline output directories (contents ignored, structure kept)
data/fetched/*
!data/fetched/.gitkeep
# Curated, redacted samples (Spec 013) — explicitly published
!data/fetched/samples/
!data/fetched/samples/**
data/evaluated/*
!data/evaluated/.gitkeep
# Curated, redacted samples (Spec 013) — explicitly published
!data/evaluated/samples/
!data/evaluated/samples/**
data/preprocessed/*
!data/preprocessed/.gitkeep
data/embeddings/*
!data/embeddings/.gitkeep
# Curated, redacted samples (Spec 013) — explicitly published
!data/embeddings/samples/
!data/embeddings/samples/**

# Archive / backup folders inside data/
data/**/.old_*
data/**/deep_eval_*

# Pipeline logs (keep status tracking, ignore large logs)
data/logs/*.log
data/logs/pipeline_progress.json
!data/logs/.gitkeep
!data/logs/pipeline_runs.json
!data/logs/pipeline_runs.schema.json

# Fetched wiki content (large)
content_output/
fetched_at_*/

# =============================================================================
# Logs
# =============================================================================
*.log
/logs/
!logs/.gitkeep
pipeline/*/logs/
!pipeline/*/logs/.gitkeep

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml

# Docker .env (contains local paths, never commit)
backend_services/.env
!backend_services/.env.template

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Temporary files
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
*.cache
nul

# =============================================================================
# Cursor / AI Tool Artifacts
# =============================================================================
*.skill
graphify-out/

# =============================================================================
# Test & Coverage
# =============================================================================
.coverage
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# =============================================================================
# Evaluation (generated / local corpora)
# =============================================================================
evaluation/test_corpus/
evaluation/ground_truth/*.json
!evaluation/ground_truth/leowiki_qa_50_verified.json
evaluation/results/**/*.json
evaluation/results/**/*.tex

# =============================================================================
# Pipeline (local artifacts)
# =============================================================================
pipeline/01_wiki_fetcher/api_method_test_results.json
.prompts/Full_test_run_I_omitted_only_lines_which_200_ok_for_breivity_here.txt

# =============================================================================
# Misc
# =============================================================================
tstex_modules/_api.ts

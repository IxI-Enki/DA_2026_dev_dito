# =============================================================================
# Dev Dito - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust paths for your system.
#
#   cp .env.template .env
#
# The .env file is git-ignored and will NOT be committed.
# =============================================================================

# ---- DokuWiki Instance Root ----
# Path to your DokuWiki installation directory (the one containing config/
# and data/ subdirectories).
# Used by the "wiki" profile: docker compose --profile wiki up -d
#
# Example (Windows):
#   WIKI_ROOT=C:\path\to\legacy-stack\development\first_own_dokuwiki
#
# Example (Linux/macOS):
#   WIKI_ROOT=/home/user/dokuwiki
#
WIKI_ROOT=

# ---- User / Group IDs (Linux only, ignored on Windows/macOS) ----
# PUID=1000
# PGID=1000

# ---- Timezone ----
# TZ=Europe/Vienna

# ---- OpenAI API Key (for embeddings pipeline) ----
# OPENAI_API_KEY=sk-...
